# Core server settings.
LISTEN_ADDR=127.0.0.1:8081
DATABASE_URL=
DB_MAX_OPEN_CONNS=5
DB_MAX_IDLE_CONNS=2
DB_CONN_MAX_IDLE_TIME=5m
DB_CONN_MAX_LIFETIME=30m
GHREPLICA_BASE_URL=
ALLOW_UNAUTH_WRITES=false
ENABLE_BACKGROUND_WORKER=true
WORKER_POLL_INTERVAL=2s
EMBEDDING_MODEL=local-hash@1

# GitHub OAuth device flow for `prtags auth login`.
PRTAGS_GITHUB_OAUTH_CLIENT_ID=
# Leave blank to use the default scope: read:org repo
PRTAGS_GITHUB_OAUTH_SCOPE=
# Leave blank to use github.com.
PRTAGS_GITHUB_OAUTH_BASE_URL=
# Leave blank to use api.github.com.
PRTAGS_GITHUB_API_URL=

# Reserved for the future GitHub App used by comment sync.
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY_PATH=
GITHUB_APP_PRIVATE_KEY_PEM=
# Leave blank to use api.github.com.
GITHUB_BASE_URL=
