# Copy this file to deploy/gcp/prtags.env on the VM and fill in the values.
#
# Optional companion files:
# - deploy/gcp/github-oauth.env for GitHub OAuth device-flow settings
# - deploy/gcp/github-app.env for GitHub App comment-sync settings

# URL-encoded IAM database username for the shared Cloud SQL proxy, for example:
# bob-gcloud%40dutiful-20260414.iam
DB_IAM_USER_URLENCODED=

# Database name already provisioned for PRtags.
DB_NAME=prtags

# Keep these conservative on the shared Cloud SQL instance unless you have
# intentionally moved workers onto a separate process or database.
DB_MAX_OPEN_CONNS=5
DB_MAX_IDLE_CONNS=2
DB_CONN_MAX_IDLE_TIME=5m
DB_CONN_MAX_LIFETIME=30m

# Base URL for the live ghreplica instance that PRtags reads from.
GHREPLICA_BASE_URL=https://ghreplica.dutiful.dev

# Leave blank to use api.github.com for comment sync.
GITHUB_BASE_URL=

# Leave false in production.
ALLOW_UNAUTH_WRITES=false

# Keep the single-process background worker enabled unless you intentionally split it out.
ENABLE_BACKGROUND_WORKER=true
WORKER_POLL_INTERVAL=2s

# Local default embedding provider.
EMBEDDING_MODEL=local-hash@1
