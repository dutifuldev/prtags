# Copy this file to deploy/gcp/github-app.env on the VM and fill in the values
# after creating and installing the GitHub App for comment sync.
#
# The private key path should point at the mounted secrets directory from
# deploy/gcp/docker-compose.yml. Keep the directory at mode 0500 and the key
# file at mode 0400, both owned by uid/gid 10001 on the VM.

GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=

# Set one of the private key options below. Prefer the mounted file path in
# production, for example /home/bob/prtags/secrets/github-app.private-key.pem.
GITHUB_APP_PRIVATE_KEY_PATH=
GITHUB_APP_PRIVATE_KEY_PEM=

# Leave blank to use api.github.com.
GITHUB_BASE_URL=
